<?xml version="1.0" encoding="utf-8"?>
<mujoco model="fr5_mobile_robot scene">
  <!-- 包含机器人URDF模型 -->
  <include file="robot.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" />
    
    <!-- 可操作物体 -->
    <body name="box1" pos="2.0 -1.0 0.6">
      <inertial pos="0 0 0" mass="0.01" diaginertia="0.001 0.001 0.001"/>
      <freejoint name="box1_joint"/>
      <geom type="box" name="box1" size="0.02 0.02 0.02" condim="3"
       friction="1 .03 .003" rgba="0 1 0 1" contype="2" conaffinity="1" solref="0.01 1"/>
      <site name="box_site1"/>
    </body>
    
    <body name="box2" pos="7.2 -2.4 0.6">
      <inertial pos="0 0 0" mass="0.01" diaginertia="0.001 0.001 0.001"/>
      <freejoint name="box2_joint"/>
      <geom type="box" name="box2" size="0.02 0.02 0.02" condim="3"
       friction="1 .03 .003" rgba="0 1 0 1" contype="2" conaffinity="1" solref="0.01 1"/>
      <site name="box_site2"/>
    </body>

    <!-- 环境障碍物（支撑表面） -->
    <body name="table1" pos="2.0 -1.0 0.29">
      <geom name="table1" pos="0 0 0" type="cylinder" size="0.2 0.29" rgba="0.5 0.5 0.5 1" />
    </body>
    
    <body name="table2" pos="4.0 -2.0 0.29">
      <geom name="table2" pos="0 0 0" type="cylinder" size="0.2 0.29" rgba="0.5 0.5 0.5 1" />
    </body>
    
    <body name="table3" pos="7.2 -2.4 0.29">
      <geom name="table3" pos="0 0 0" type="cylinder" size="0.2 0.29" rgba="0.5 0.5 0.5 1" />
    </body>
    
    <body name="table4" pos="11.5 0.8 0.29">
      <geom name="table4" pos="0 0 0" type="cylinder" size="0.2 0.29" rgba="0.5 0.5 0.5 1" />
    </body>

    <!-- 任务参考点：抓取位置和放置位置 -->
    <!-- 水平抓取：x 为夹爪开口方向，z 朝物体，y 为爪面法向。
         当前目标姿态要求 z 对齐世界 -y。 -->
    <site name="grasp_object1" pos="2.0 -1.0 0.60" quat="0.70710678 0.70710678 0 0" />
    <site name="drop_location1" pos="4.0 -2.0 0.60" quat="0.70710678 0.70710678 0 0" />
    
    <site name="grasp_object2" pos="7.2 -2.4 0.60" quat="0.70710678 0.70710678 0 0" />
    <site name="drop_location2" pos="11.5 0.8 0.60" quat="0.70710678 0.70710678 0 0" />
    
    <site name="grasp_object3" pos="2.0 -2.0 0.60" quat="0.70710678 0.70710678 0 0" />
  </worldbody>

</mujoco>